# Auto detect text files and perform LF normalization
* text=auto

# JavaScript
*.js text eol=lf
*.jsx text eol=lf

# TypeScript
*.ts text eol=lf
*.tsx text eol=lf

# JSON
*.json text eol=lf

# Markdown
*.md text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf

# Fonts
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Configuration files
*.config.js text eol=lf
*.config.mjs text eol=lf
next.config.mjs text eol=lf
tailwind.config.js text eol=lf
postcss.config.js text eol=lf

# Package files
package.json text eol=lf
package-lock.json text eol=lf
yarn.lock text eol=lf
pnpm-lock.yaml text eol=lf