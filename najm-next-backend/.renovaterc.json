{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticPrefixFixDepsChangelog",
    ":ignoreUnstable",
    "group:monorepos",
    "group:recommended",
    "workarounds:all"
  ],
  "schedule": ["before 4am on Monday"],
  "timezone": "UTC",
  "labels": ["dependencies"],
  "assignees": ["@me"],
  "reviewers": ["@me"],
  "packageRules": [
    {
      "description": "Group Next.js monorepo packages together",
      "groupName": "Next.js packages",
      "matchPackagePrefixes": ["@next/"]
    },
    {
      "description": "Group React packages",
      "groupName": "React packages",
      "matchPackageNames": [
        "react",
        "react-dom",
        "@types/react",
        "@types/react-dom"
      ]
    },
    {
      "description": "Group testing packages",
      "groupName": "Testing packages",
      "matchPackagePrefixes": ["@testing-library/", "jest", "cypress"]
    },
    {
      "description": "Group ESLint packages",
      "groupName": "ESLint packages",
      "matchPackagePrefixes": ["eslint", "@eslint/"]
    },
    {
      "description": "Automerge patch updates for dev dependencies",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "Automerge minor updates for dev dependencies",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor"],
      "automerge": true
    },
    {
      "matchPackagePatterns": ["^@next"],
      "groupName": "Next.js packages"
    },
    {
      "matchPackagePatterns": ["^@tailwindcss"],
      "groupName": "Tailwind CSS packages"
    },
    {
      "matchPackageNames": ["next"],
      "allowedVersions": "<17.0.0"
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "osvVulnerabilityAlerts": true,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 4am on Monday"]
  }
}
